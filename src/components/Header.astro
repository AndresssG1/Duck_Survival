---
import { navigation } from '../data/navigation';

const isActive = (prefixes: string[]) => prefixes.some((prefix) => Astro.url.pathname.startsWith(prefix));
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label="Duck Survival Guía, inicio">
      <span class="brand-mark" aria-hidden="true">DS</span>
      <span><strong>Duck Survival</strong><small>Guía en español</small></span>
    </a>
    <nav class="desktop-navigation" aria-label="Navegación principal">
      <ul>
        {navigation.map((item) => (
          <li><a class={isActive(item.activePrefixes) ? 'active' : ''} href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <details class="mobile-navigation">
      <summary>Menú</summary>
      <nav aria-label="Navegación móvil">
        <ul>
          {navigation.map((item) => (
            <li><a class={isActive(item.activePrefixes) ? 'active' : ''} href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    </details>
  </div>
</header>
