---
import type { Character } from '../data/characters';

interface Props {
  character: Character;
  reverse?: boolean;
  elementColor: string;
  elementName: string;
}

const { character, reverse = false, elementColor, elementName } = Astro.props;
const rarityClasses: Record<string, string> = {
  'Épico': 'rarity-epic',
  'Místico': 'rarity-mythic',
  'Legendario': 'rarity-legendary',
};
const rarityClass = rarityClasses[character.rarity] ?? 'rarity-default';
---

<article class:list={['character-row', rarityClass, { reverse }]} style={`--element-color:${elementColor}`}>
  <div class="character-portrait">
    {character.image ? (
      <img src={character.image} alt={character.imageAlt} loading="lazy" width="620" height="620" />
    ) : (
      <div class="portrait-placeholder" role="img" aria-label={`Imagen pendiente de ${character.name}`}>
        <span>Imagen pendiente</span>
      </div>
    )}
  </div>
  <div class="character-info">
    <div class="character-tags">
      <span>{elementName}</span><span class="rarity-tag">{character.rarity}</span>
    </div>
    <h2>{character.name}</h2>
    <p>{character.description}</p>
    <div class="character-acquisition">
      <h3>Cómo se obtiene</h3>
      <p>{character.acquisition}</p>
    </div>
    <div class="ability-list">
      {character.abilities.map((ability) => (
        <section class="ability-card">
          <img src={ability.image} alt={`Icono de ${ability.name}`} width="76" height="76" loading="lazy" />
          <div>
            <span>{ability.type}</span>
            <h3>{ability.name}</h3>
            <p>{ability.description}</p>
            {ability.unlock && <small>{ability.unlock}</small>}
          </div>
        </section>
      ))}
    </div>
    {character.linkedAbility && (
      <section class="linked-ability">
        <span>Habilidad enlazada: {character.linkedAbility.name}</span>
        <h3>{character.linkedAbility.passiveName} <small>(pasiva única)</small></h3>
        <p>{character.linkedAbility.description}</p>
      </section>
    )}
    <p class="progression-note">{character.progressionNote}</p>
    <small>{character.verifiedAt ? `Verificado: ${character.verifiedAt} | Versión ${character.gameVersion}` : 'Ficha pendiente de verificación'}</small>
  </div>
</article>
