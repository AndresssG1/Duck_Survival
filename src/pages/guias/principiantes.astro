---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const menuItems = [
  { label: 'Qué es', href: '#que-es' },
  { label: 'Primeros pasos', href: '#primeros-pasos' },
  { label: 'Cómo funciona', href: '#como-funciona' },
  { label: 'Construcciones', href: '#construcciones' },
  { label: 'Héroes', href: '#heroes' },
  { label: 'Skills', href: '#skills' },
  { label: 'Por qué perdiste', href: '#por-que-perdiste' },
  { label: 'Errores', href: '#errores' },
];

const firstSteps = [
  { text: 'Reclama todos los regalos disponibles.', href: null },
  { text: 'Canjea los códigos activos.', href: '/codigos/' },
  { text: 'Completa el tutorial inicial.', href: null },
  { text: 'Reclama las recompensas del correo.', href: null },
  { text: 'Únete a un gremio cuando se desbloquee.', href: null },
  { text: 'Evita gastar recursos sin un objetivo definido.', href: null },
];

const buildingPriorities = [
  { stars: 5, name: 'Gold Mine', reason: 'Más oro para sostener las mejoras.' },
  { stars: 5, name: 'Survivor Camp', reason: 'Mejora los ingresos de la base.' },
  { stars: 4, name: 'Machine Gun Turret', reason: 'Aporta daño durante las primeras defensas.' },
  { stars: 4, name: 'Infantry Camp', reason: 'Refuerza la defensa con unidades.' },
];

const teamFunctions = [
  { number: '01', title: 'DPS', description: 'Su función principal es eliminar enemigos mediante daño constante o explosivo.' },
  { number: '02', title: 'Defensa', description: 'Ayuda a resistir daño, proteger la formación o mantener la base en pie.' },
  { number: '03', title: 'Control', description: 'Reduce la presión mediante congelación, aturdimiento u otros efectos.' },
];

const skillTypes = [
  { title: 'Daño en área', use: 'Cuando varias unidades llegan juntas.' },
  { title: 'Daño a jefe', use: 'Cuando el problema es un solo enemigo resistente.' },
  { title: 'Congelación', use: 'Para frenar el avance y ganar tiempo.' },
  { title: 'Escudos', use: 'Para sobrevivir cuando falta resistencia.' },
  { title: 'Velocidad de ataque', use: 'Para aumentar la frecuencia de daño de una formación preparada.' },
];

const lossDiagnostics = [
  { problem: 'La base cayó', solution: 'Revisar defensa y supervivencia.' },
  { problem: 'Los enemigos sobreviven demasiado', solution: 'Aumentar el daño disponible.' },
  { problem: 'Llegan demasiados enemigos', solution: 'Incorporar control o daño en área.' },
  { problem: 'El jefe no muere', solution: 'Priorizar daño a objetivo único.' },
];

const commonErrors = [
  { title: 'Gastar recursos en muchos héroes', correction: 'Define primero una formación principal.' },
  { title: 'Ignorar la economía', correction: 'Comprueba si tus ingresos sostienen las mejoras.' },
  { title: 'Mejorar todo por igual', correction: 'Invierte segun el problema que necesitas resolver.' },
  { title: 'No analizar la derrota', correction: 'Identifica si faltó daño, defensa o control.' },
  { title: 'No utilizar control', correction: 'Congelar o aturdir puede darte tiempo para eliminar una horda.' },
];
---

<BaseLayout title="Guía para principiantes" description="Guía visual de Duck Survival con primeros pasos, construcciones, héroes, skills y diagnóstico de derrotas.">
  <PageHero eyebrow="Tomo I · Fundamentos" title="Guía para principiantes" description="Encuentra rápidamente lo que necesitas para comprender el juego y tomar mejores decisiones desde el inicio." />

  <nav class="guide-jump-nav" aria-label="Secciones de la guía">
    <div class="shell">
      {menuItems.map((item, index) => <a href={item.href}><span>{String(index + 1).padStart(2, '0')}</span>{item.label}</a>)}
    </div>
  </nav>

  <div class="guide-draft-note shell"><strong>Diseño base</strong><span>Las prioridades y recomendaciones se completarán y verificarán con información del juego.</span></div>

  <section class="beginner-section intro-section shell" id="que-es">
    <div class="section-number">01</div>
    <div class="section-copy"><p class="eyebrow">En menos de un minuto</p><h2>Qué es Duck Survival</h2><p>Duck Survival combina preparación de base, héroes y habilidades con combates contra hordas. Durante el día organizas recursos y defensas; durante la noche debes resistir el ataque y mantener tu base en pie.</p><a class="text-link" href="/guias/que-es-duck-survival/">Leer la explicación completa -&gt;</a></div>
    <div class="concept-stack">{['Construye de día','Defiende de noche','Mejora tu base','Recluta héroes','Sobrevive a las hordas'].map((concept) => <span>{concept}</span>)}</div>
  </section>

  <section class="beginner-section checklist-section" id="primeros-pasos">
    <div class="shell"><div class="section-heading-inline"><div><p class="eyebrow">Empieza con orden</p><h2>Primeros pasos</h2></div><span class="section-number">02</span></div>
      <div class="starter-checklist">{firstSteps.map((step) => step.href ? <a href={step.href}><span aria-hidden="true">✓</span>{step.text}<b aria-hidden="true">-&gt;</b></a> : <div><span aria-hidden="true">✓</span>{step.text}</div>)}</div>
    </div>
  </section>

  <section class="beginner-section shell" id="como-funciona">
    <div class="section-heading-inline"><div><p class="eyebrow">El ciclo principal</p><h2>Cómo funciona el juego</h2></div><span class="section-number">03</span></div>
    <div class="day-night-flow">
      <article class="phase-card day-phase"><span>Fase 01</span><h3>Día</h3><ul><li>Construye edificios.</li><li>Mejora la economía.</li><li>Prepara las defensas.</li></ul></article>
      <div class="flow-arrow" aria-hidden="true">-&gt;</div>
      <article class="phase-card night-phase"><span>Fase 02</span><h3>Noche</h3><ul><li>Resiste las hordas.</li><li>Sobrevive a la oleada.</li><li>Derrota al jefe.</li></ul></article>
    </div>
  </section>

  <section class="beginner-section building-section" id="construcciones">
      <div class="shell"><div class="section-heading-inline"><div><p class="eyebrow">Prioridades provisionales</p><h2>Qué construir primero</h2></div><span class="section-number">04</span></div>
      <div class="building-priority-grid">{buildingPriorities.map((building) => <article><div class="priority-stars" aria-label={`${building.stars} de 5 estrellas`}>{'★'.repeat(building.stars)}<span>{'★'.repeat(5-building.stars)}</span></div><h3>{building.name}</h3><p>{building.reason}</p></article>)}</div>
      <a class="button secondary" href="/construcciones/">Explorar construcciones</a>
    </div>
  </section>

  <section class="beginner-section shell" id="heroes">
    <div class="section-heading-inline"><div><p class="eyebrow">Funciones educativas</p><h2>Héroes para principiantes</h2></div><span class="section-number">05</span></div>
    <p class="section-lead">El juego no asigna roles oficiales. Estas funciones sirven para comprender qué aporta cada héroe dentro de un equipo.</p>
    <div class="team-function-grid">{teamFunctions.map((role) => <article><span>{role.number}</span><h3>{role.title}</h3><p>{role.description}</p></article>)}</div>
    <a class="button secondary" href="/personajes/">Explorar personajes</a>
  </section>

  <section class="beginner-section skills-section" id="skills">
      <div class="shell"><div class="section-heading-inline"><div><p class="eyebrow">Elige según el problema</p><h2>Skills básicas</h2></div><span class="section-number">06</span></div>
      <div class="basic-skill-list">{skillTypes.map((skill, index) => <article><span>{String(index + 1).padStart(2, '0')}</span><div><h3>{skill.title}</h3><p>{skill.use}</p></div></article>)}</div>
      <a class="button secondary" href="/habilidades/">Explorar habilidades</a>
    </div>
  </section>

  <section class="beginner-section shell" id="por-que-perdiste">
    <div class="section-heading-inline"><div><p class="eyebrow">Diagnóstico rápido</p><h2>Cómo saber por qué perdiste</h2></div><span class="section-number">07</span></div>
    <div class="diagnostic-grid">{lossDiagnostics.map((item) => <article><div><span>Problema</span><strong>{item.problem}</strong></div><div class="diagnostic-arrow" aria-hidden="true">-&gt;</div><div><span>Revisa</span><strong>{item.solution}</strong></div></article>)}</div>
  </section>

  <section class="beginner-section errors-section" id="errores">
    <div class="shell"><div class="section-heading-inline"><div><p class="eyebrow">Evita frenar tu progreso</p><h2>Errores comunes</h2></div><span class="section-number">08</span></div>
      <div class="error-list">{commonErrors.map((error, index) => <article><span>#{index + 1}</span><div><h3>{error.title}</h3><p>{error.correction}</p></div></article>)}</div>
    </div>
  </section>
</BaseLayout>
