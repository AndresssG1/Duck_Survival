---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const volumes = [
  {
    number: 'Tomo I',
    title: 'Principiantes',
    range: 'Fundamentos',
    description: 'Aprende el ciclo de juego, prepara tu base y comprende los primeros sistemas.',
    status: 'En desarrollo',
    href: '/guias/principiantes/',
    className: 'guide-beginner',
  },
  {
    number: 'Tomo II',
    title: 'Intermedio',
    range: 'Progresión de cuenta',
    description: 'Comprende patrullas, formaciones, desafíos, equipo y gestión de recursos.',
    status: 'En revisión',
    href: '/guias/intermedio/',
    className: 'guide-intermediate',
  },
  {
    number: 'Tomo III',
    title: 'Experto',
    range: 'Estrategias avanzadas',
    description: 'Comparte estrategias avanzadas para que puedan verificarse y convertirse en nuevas guías.',
    status: 'Comunidad',
    href: '/guias/experto/',
    className: 'guide-expert',
  },
];

const guideNeeds = [
  { number: '01', label: 'Empezar', title: 'Nunca he jugado', description: 'Aprende el ciclo del juego, qué revisar primero y cómo evitar errores básicos.', href: '/guias/principiantes/' },
  { number: '02', label: 'Progresión', title: 'Quiero aumentar CP', description: 'Compara gemas, coleccionables, Titanes, héroes y construcciones.', href: '/guias/como-aumentar-cp/' },
  { number: '03', label: 'PvE', title: 'No supero un capítulo', description: 'Revisa elementos, oleadas, torres y muros de progresión conocidos.', href: '/guias/meta-pve-y-capitulos/' },
  { number: '04', label: 'Equipamiento', title: '¿Qué arma desarrollo?', description: 'Consulta rutas comunitarias F2P y opciones de juego avanzado.', href: '/guias/armas-y-progresion/' },
  { number: '05', label: 'Recursos', title: 'No quiero malgastar', description: 'Decide cuándo usar diamantes, tickets y monedas especiales.', href: '/guias/economia-f2p/' },
  { number: '06', label: 'Competición', title: 'Quiero mejorar en Arena', description: 'Comprende rangos, intentos, composición y errores frecuentes de PvP.', href: '/eventos/desafios/arena/' },
  { number: '07', label: 'Cuenta', title: 'Cambio de servidor o móvil', description: 'Revisa vinculación, transferencias y procedimientos de soporte.', href: '/guias/servidores-y-cuentas/' },
  { number: '08', label: 'Ayuda', title: 'Tengo un problema técnico', description: 'Sigue pasos seguros antes de reinstalar o contactar al soporte.', href: '/guias/problemas-frecuentes/' },
];
---

<BaseLayout title="Guías" description="Guías de Duck Survival organizadas desde los fundamentos hasta estrategias avanzadas.">
  <PageHero eyebrow="Resuelve una necesidad" title="Guías" description="Empieza por tu objetivo actual o sigue la ruta completa desde los fundamentos hasta las estrategias comunitarias." />
  <section class="section shell guide-needs-section">
    <div class="section-heading"><div><p class="eyebrow">Encuentra tu ruta</p><h2>¿Qué necesitas resolver?</h2></div></div>
    <div class="guide-needs-grid">{guideNeeds.map((item) => <a href={item.href}><span>{item.number} · {item.label}</span><h2>{item.title}</h2><p>{item.description}</p><b>Abrir guía →</b></a>)}</div>
  </section>
  <section class="section guide-volumes-section"><div class="shell">
    <div class="section-heading"><div><p class="eyebrow">Ruta completa</p><h2>Aprende por etapas</h2></div></div>
    <div class="guide-volume-grid">
      {volumes.map((volume) => (
        <a class={`guide-volume ${volume.className}`} href={volume.href}>
          <div class="volume-top"><span>{volume.number}</span><b>{volume.status}</b></div>
          <h2>{volume.title}</h2>
          <p class="volume-range">{volume.range}</p>
          <p>{volume.description}</p>
          <strong>Entrar al tomo <span aria-hidden="true">-&gt;</span></strong>
        </a>
      ))}
    </div>
    <a class="game-intro-link" href="/guias/que-es-duck-survival/">
      <span>Antes de comenzar</span>
      <div><h2>Qué es Duck Survival</h2><p>Conoce el ciclo día/noche, los elementos y los modos confirmados.</p></div>
      <b aria-hidden="true">-&gt;</b>
    </a>
  </div></section>
</BaseLayout>
