---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import StatusPill from '../components/StatusPill.astro';
import { gameCodes } from '../data/codes';

const activeCount = gameCodes.filter((item) => item.status === 'active').length;
const inactiveCount = gameCodes.filter((item) => item.status === 'expired').length;
const formatDate = (date: string) => new Intl.DateTimeFormat('es', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' }).format(new Date(`${date}T00:00:00Z`));
---
<BaseLayout title="Códigos" description="Códigos activos de Duck Survival, estado, caducidad y fecha de verificación.">
  <PageHero eyebrow="Recompensas" title="Códigos de Duck Survival" description="Lista comprobada manualmente y actualizada regularmente con códigos activos e inactivos." />
  <section class="section shell narrow">
    <div class="notice"><strong>Actualización regular</strong><p>Estos códigos fueron canjeados y comprobados manualmente el 18 de junio de 2026. Pueden utilizarse una sola vez por cuenta y dejar de funcionar sin aviso.</p></div>
    <div class="code-filters" aria-label="Filtrar códigos">
      <button type="button" data-code-filter="all" aria-pressed="true">Todos <span>{gameCodes.length}</span></button>
      <button type="button" data-code-filter="active" aria-pressed="false">Activos <span>{activeCount}</span></button>
      <button type="button" data-code-filter="expired" aria-pressed="false">Inactivos <span>{inactiveCount}</span></button>
    </div>
    <div class="codes-list full" id="codes-list">
      {gameCodes.map((item) => (
        <div class="code-row" data-code-status={item.status}>
          <div>
            <div class="code-name"><code>{item.code}</code>{item.isNew && <span>Nuevo</span>}</div>
            <small>{item.reward}</small>
            <small class="code-date">{item.expiresAt ? `Válido hasta el ${formatDate(item.expiresAt)}` : `Verificado el ${formatDate(item.verifiedAt!)}`}</small>
          </div>
          <StatusPill status={item.status} />
        </div>
      ))}
      <p class="codes-empty" id="codes-empty" hidden>No hay códigos con este estado.</p>
    </div>
    <section class="redeem-steps">
      <p class="eyebrow">Paso a paso</p>
      <h2>Cómo canjear códigos</h2>
      <ol>
        <li>Abre Duck Survival.</li>
        <li>Toca el avatar del perfil del pato en la esquina superior izquierda.</li>
        <li>Pulsa el botón <strong>Código de regalo</strong>.</li>
        <li>Escribe el código respetando mayúsculas y minúsculas, y confirma el canje.</li>
      </ol>
    </section>
  </section>
  <script>
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-code-filter]');
    const codeRows = document.querySelectorAll<HTMLElement>('[data-code-status]');
    const emptyMessage = document.querySelector<HTMLElement>('#codes-empty');

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.codeFilter;
        let visible = 0;

        filterButtons.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
        codeRows.forEach((row) => {
          const show = filter === 'all' || row.dataset.codeStatus === filter;
          row.hidden = !show;
          if (show) visible += 1;
        });
        if (emptyMessage) emptyMessage.hidden = visible !== 0;
      });
    });
  </script>
</BaseLayout>
