---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatusPill from '../components/StatusPill.astro';
import { gameCodes } from '../data/codes';
import { characters } from '../data/characters';
import { skills } from '../data/skills';
import { buildingCategories } from '../data/buildings';
import { upcomingAnnouncements, officialNews } from '../data/updates';

const finderItems = [
  { number: '01', title: 'Códigos activos', description: 'Canjea recompensas comprobadas y revisa su fecha de verificación.', category: 'Respuesta rápida', href: '/codigos/', keywords: 'codigo códigos regalos recompensas canjear gratis' },
  { number: '02', title: 'Arena PvP', description: 'Rangos, puntos, intentos, Pase y estrategia competitiva.', category: 'Modo de juego', href: '/eventos/desafios/arena/', keywords: 'arena pvp rango maestro experto campeón puntos pase combate' },
  { number: '03', title: 'Guía para principiantes', description: 'Comprende el ciclo del juego y evita los primeros errores.', category: 'Empezar', href: '/guias/principiantes/', keywords: 'principiante empezar tutorial edificios heroes perder' },
  { number: '04', title: '¿Por qué estás bloqueado?', description: 'Diagnostica si falta daño, defensa, control o progreso.', category: 'Progresión', href: '/guias/intermedio/#bloqueos', keywords: 'bloqueado capítulo perder daño defensa control progresion cp' },
  { number: '05', title: 'Personajes', description: 'Busca héroes por elemento y consulta todas sus habilidades.', category: 'Base de datos', href: '/personajes/', keywords: 'personajes heroes héroes elemento rareza habilidad definitiva' },
  { number: '06', title: 'Habilidades', description: 'Compara efectos, elementos, calidad y usos estratégicos.', category: 'Base de datos', href: '/habilidades/', keywords: 'habilidad skill skills calidad estrellas elemento daño control' },
  { number: '07', title: 'Construcciones', description: 'Consulta la Base, Ingeniería y las mejoras de cada opción.', category: 'Base de datos', href: '/construcciones/', keywords: 'base edificio construccion ingeniería nivel fragmentos torre muralla' },
  { number: '08', title: 'Próximos eventos', description: 'Mira qué contenido ha sido anunciado antes de su lanzamiento.', category: 'Novedades', href: '/novedades/proximos-eventos/', keywords: 'proximo próximo evento anuncio calendario nuevo contenido' },
];

const goals = [
  { label: 'Soy nuevo', title: 'Aprender lo esencial', text: 'Ciclo día/noche, primeras decisiones y errores comunes.', href: '/guias/principiantes/' },
  { label: 'Estoy atascado', title: 'Superar un bloqueo', text: 'Identifica si el problema es daño, defensa, control o progreso.', href: '/guias/intermedio/#bloqueos' },
  { label: 'Quiero competir', title: 'Mejorar en Arena', text: 'Prepara tu formación, usa tus intentos y entiende los rangos.', href: '/eventos/desafios/arena/' },
  { label: 'Antes de gastar', title: 'Revisar mis recursos', text: 'Compara prioridades antes de utilizar diamantes o materiales.', href: '/guias/intermedio/#recursos' },
];

const recentCodes = gameCodes.filter((item) => item.status === 'active').slice(0, 3);
const documentedBuildings = buildingCategories.reduce((total, category) => total + category.options.length, 0);
const latestUpdates = [
  ...upcomingAnnouncements.map((item) => ({ type: 'Próximo evento', title: item.title, date: item.announcedAt, href: '/novedades/proximos-eventos/' })),
  ...officialNews.map((item) => ({ type: item.category, title: item.title, date: item.publishedAt, href: '/novedades/noticias/' })),
].sort((a, b) => b.date.localeCompare(a.date)).slice(0, 2);
---

<BaseLayout title="Duck Survival Guía" description="La guía más completa de Duck Survival en español. Códigos actualizados, héroes, estrategias, gremios, eventos y consejos para principiantes.">
  <section class="hero home-hero">
    <div class="shell hero-grid">
      <div>
        <p class="eyebrow">Respuestas para sobrevivir mejor</p>
        <h1>Encuentra lo que necesitas.<br /><span>Vuelve al combate.</span></h1>
        <p class="lead">Guías prácticas y datos verificables de Duck Survival, organizados para llegar a una respuesta sin recorrer toda la wiki.</p>
        <div class="actions"><a class="button primary" href="/codigos/">Ver códigos activos</a><a class="button secondary" href="/eventos/desafios/arena/">Guía de Arena</a></div>
      </div>
      <div class="home-status-panel" aria-label="Estado de la base de conocimiento"><span>Wiki comunitaria · v1</span><strong>{characters.length + skills.length + documentedBuildings}</strong><p>fichas de personajes, habilidades y construcciones disponibles</p><div><b>{characters.length}</b> personajes <b>{skills.length}</b> habilidades <b>{documentedBuildings}</b> construcciones</div></div>
    </div>
  </section>

  <section class="section shell home-finder-section">
    <div class="home-finder-heading"><div><p class="eyebrow">Acceso rápido</p><h2>¿Qué estás buscando?</h2><p>Escribe una palabra como “Arena”, “código”, “daño” o “construcción”.</p></div><label for="home-finder"><span>Buscar en accesos rápidos</span><input id="home-finder" type="search" placeholder="Ejemplo: Arena PvP" autocomplete="off" /></label></div>
    <div class="home-finder-grid" id="home-finder-results">
      {finderItems.map((item) => <a class="home-finder-card" href={item.href} data-search={`${item.title} ${item.description} ${item.category} ${item.keywords}`.toLowerCase()}><span>{item.number} · {item.category}</span><h3>{item.title}</h3><p>{item.description}</p><b>Abrir →</b></a>)}
    </div>
    <p class="home-finder-empty" id="home-finder-empty" hidden>No encontramos un acceso rápido con esas palabras. Prueba con “Arena”, “personajes”, “habilidades” o “códigos”.</p>
  </section>

  <section class="section home-goals-section"><div class="shell"><div class="section-heading"><div><p class="eyebrow">Elige por objetivo</p><h2>¿Qué quieres conseguir?</h2></div><a href="/guias/">Explorar todas las guías →</a></div><div class="home-goal-grid">{goals.map((goal, index) => <a href={goal.href}><span>0{index + 1} · {goal.label}</span><h3>{goal.title}</h3><p>{goal.text}</p><b>Empezar →</b></a>)}</div></div></section>

  <section class="section shell home-two-panels">
    <div><div class="section-heading"><div><p class="eyebrow">Actualizado recientemente</p><h2>Novedades</h2></div><a href="/novedades/">Ver todas →</a></div><div class="home-update-list">{latestUpdates.map((item) => <a href={item.href}><span>{item.type}</span><time datetime={item.date}>{item.date}</time><strong>{item.title}</strong></a>)}</div></div>
    <div><div class="section-heading"><div><p class="eyebrow">Canal de suministros</p><h2>Códigos recientes</h2></div><a href="/codigos/">Ver todos →</a></div><div class="codes-list home-codes-list">{recentCodes.map((item) => <div class="code-row"><div><code>{item.code}</code><small>{item.reward}</small></div><StatusPill status={item.status} /></div>)}</div></div>
  </section>

  <section class="section home-database-section"><div class="shell home-database-callout"><div><p class="eyebrow">Consulta profunda</p><h2>Personajes, habilidades y construcciones</h2><p>Cuando ya sabes qué comparar, entra a la Base de datos. Las fichas detalladas siguen disponibles sin ocupar el primer plano.</p></div><a class="button primary" href="/base-de-datos/">Abrir Base de datos</a></div></section>

  <section class="section shell home-community-callout"><div><p class="eyebrow">Construida con jugadores</p><h2>¿Encontraste un dato nuevo?</h2><p>Comparte capturas, reglas o experiencias. Revisamos cada aporte y distinguimos información oficial, datos del juego y consenso comunitario.</p></div><a class="button secondary" href="/contacto/">Aportar información</a></section>

  <script>
    const input = document.querySelector<HTMLInputElement>('#home-finder');
    const cards = [...document.querySelectorAll<HTMLElement>('.home-finder-card')];
    const empty = document.querySelector<HTMLElement>('#home-finder-empty');
    input?.addEventListener('input', () => {
      const query = input.value.trim().toLocaleLowerCase('es');
      let visible = 0;
      cards.forEach((card) => {
        const matches = !query || card.dataset.search?.includes(query);
        card.hidden = !matches;
        if (matches) visible += 1;
      });
      if (empty) empty.hidden = visible !== 0;
    });
  </script>
</BaseLayout>
