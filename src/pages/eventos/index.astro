---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { recurringChallenges, gameEvents } from '../../data/events';

const activeEvents = gameEvents.filter((event) => event.status === 'active');
const upcomingEvents = gameEvents.filter((event) => event.status === 'upcoming');
---

<BaseLayout title="Eventos y desafíos" description="Desafíos diarios y eventos individuales o de gremio de Duck Survival.">
  <PageHero eyebrow="Actividades del juego" title="Eventos y desafíos" description="Separamos las actividades diarias de los eventos temporales para documentar correctamente sus reglas, fechas y recompensas." />
  <section class="section shell">
    <div class="activity-grid">
      <a class="activity-card daily" href="/eventos/desafios/">
        <span>Actividad recurrente</span><strong>{recurringChallenges.length}</strong><h2>Desafíos</h2>
        <p>Desafío de dificultad y Cooperación contra enemigos, con modalidades que se desbloquean mediante el progreso.</p><b>Ver desafíos -&gt;</b>
      </a>
      <a class="activity-card individual" href="/eventos/individuales/">
        <span>Calendario temporal</span><strong>{gameEvents.filter((event) => event.audience === 'individual').length}</strong><h2>Individuales</h2>
        <p>Eventos limitados que se completan mediante el progreso de cada jugador.</p><b>Ver eventos -&gt;</b>
      </a>
      <a class="activity-card guild" href="/eventos/gremio/">
        <span>Calendario temporal</span><strong>{gameEvents.filter((event) => event.audience === 'guild').length}</strong><h2>Gremio</h2>
        <p>Eventos limitados cuyo progreso o recompensas dependen del gremio.</p><b>Ver eventos -&gt;</b>
      </a>
    </div>
    <div class="event-overview">
      <div><p class="eyebrow">Estado actual</p><h2>{activeEvents.length} eventos activos</h2><p>{upcomingEvents.length} eventos próximos registrados.</p></div>
      <div><h3>Qué documentaremos</h3><ul><li>Funcionamiento y requisitos</li><li>Calendario y fases</li><li>Recompensas y puntuación</li><li>Fuente y fecha de verificación</li></ul></div>
    </div>
  </section>
</BaseLayout>
