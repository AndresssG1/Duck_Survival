---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { gameEvents } from '../data/events';

const activeEvents = gameEvents.filter((event) => event.status === 'active');
const upcomingEvents = gameEvents.filter((event) => event.status === 'upcoming');
const endedEvents = gameEvents.filter((event) => event.status === 'ended');
---

<BaseLayout title="Eventos" description="Eventos activos, próximos y finalizados de Duck Survival con fuentes verificadas.">
  <PageHero eyebrow="Calendario" title="Eventos" description="Seguimiento de eventos, fechas y recompensas confirmadas en canales oficiales de Duck Survival." />
  <section class="section shell narrow">
    <div class="notice"><strong>Sin eventos confirmados</strong><p>Añadiremos un evento cuando podamos verificar sus fechas y recompensas en Google Play, Facebook o Discord oficial.</p></div>
    <div class="event-summary" aria-label="Resumen de eventos">
      <div><strong>{activeEvents.length}</strong><span>Activos</span></div>
      <div><strong>{upcomingEvents.length}</strong><span>Próximos</span></div>
      <div><strong>{endedEvents.length}</strong><span>Finalizados</span></div>
    </div>
    <h2>Criterio de publicación</h2>
    <p>Cada evento mostrará estado, inicio, finalización, recompensas, fuente y fecha de verificación. Los anuncios comunitarios sin respaldo oficial permanecerán fuera del calendario.</p>
  </section>
</BaseLayout>
