---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { upcomingAnnouncements } from '../../data/updates';
import { existsSync } from 'node:fs';
import { join } from 'node:path';

const statusLabels = { announced: 'Anunciado', 'coming-soon': 'Proximamente', active: 'Activo', ended: 'Finalizado' };
const hasCover = (cover?: string) => Boolean(cover && existsSync(join(process.cwd(), 'public', cover.replace(/^\//, ''))));
---

<BaseLayout title="Proximos eventos" description="Tablero de proximos eventos y contenido anunciado oficialmente para Duck Survival.">
  <PageHero eyebrow="Contenido todavia no disponible" title="Proximos eventos" description="Un tablero breve para seguir anuncios oficiales antes de que aparezcan sus reglas completas dentro del juego." />
  <section class="section shell">
    <a class="back-link" href="/novedades/">Volver a Novedades</a>
    <div class="upcoming-board">
      {upcomingAnnouncements.map((item) => (
        <article class="upcoming-announcement-card">
          <figure class={`official-cover-slot fit-${item.coverFit ?? 'contain'}`}>
            {hasCover(item.cover) ? (
              <img src={item.cover} alt={item.coverAlt ?? `Portada oficial de ${item.title}`} loading="lazy" />
            ) : (
              <div><span>Imagen oficial</span><strong>Pendiente de imagen</strong></div>
            )}
            {hasCover(item.cover) && <figcaption>{item.coverCredit ?? 'Imagen oficial de Duck Survival. Uso informativo no comercial.'}</figcaption>}
          </figure>
          <div class="upcoming-announcement-content">
            <div class="update-card-meta"><span>{statusLabels[item.status]}</span><time datetime={item.announcedAt}>Anunciado: {item.announcedAt}</time></div>
            <h2>{item.title}</h2>
            <p>{item.summary}</p>
            <div class="update-timing"><span>Calendario anunciado</span><strong>{item.timing}</strong></div>
            <ul>{item.highlights.map((highlight) => <li>{highlight}</li>)}</ul>
            <div class="update-source"><small>Verificado: {item.verifiedAt} · Resumen no oficial</small><a href={item.sourceUrl} target="_blank" rel="noopener noreferrer">Ver anuncio oficial -&gt;</a></div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
