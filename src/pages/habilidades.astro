---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
const skills = ['Meteor Strike', 'Frost Shield', 'Focused Laser'];
---
<BaseLayout title="Habilidades" description="Habilidades y elementos conocidos de Duck Survival.">
  <PageHero eyebrow="Poder de combate" title="Habilidades" description="Consulta habilidades conocidas y, próximamente, sus efectos, elementos y mejores usos." />
  <section class="section shell"><div class="card-grid compact">{skills.map((name, index) => <article class="guide-card"><span>{String(index + 1).padStart(2, '0')}</span><h2>{name}</h2><p>Estadísticas pendientes de verificación.</p></article>)}</div></section>
</BaseLayout>
